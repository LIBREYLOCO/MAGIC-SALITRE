{
  "name": "lyl-bien-raiz",
  "version": "1.0.0",
  "description": "L&L · Lógica Institucional & Liquidez — Sistema de Modelado Financiero Inmobiliario",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "npm run build && node server.js",
    "build": "esbuild js/app.js --bundle --outfile=js/app.bundle.js --format=iife --target=es2020 --minify",
    "build:watch": "esbuild js/app.js --bundle --outfile=js/app.bundle.js --format=iife --target=es2020 --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18.x"
  },
  "dependencies": {
    "@netlify/blobs": "^8.2.0",
    "bcryptjs": "^3.0.3",
    "express": "^4.18.2",
    "express-session": "^1.19.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "vitest": "^4.1.2"
  }
}
